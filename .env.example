# TapeDeck Configuration
#
# All settings are optional and have sensible defaults:
# - PORT: 3001
# - DATA_DIR: . (current directory)
# - LOG_LEVEL: info
# - DEV_MODE: false
# - REQUIRE_TLS: false
#
# Session secret, CSRF key, and encryption key are auto-generated on first run
# and stored in DATA_DIR (.session_secret, .csrf_key, .encryption_key)
#
# Database is stored in DATA_DIR/tapedeck.db
#
# Plex servers, Home Assistant, and Apple TVs are configured via the
# web-based setup wizard (creates config.yml).

# Uncomment to override defaults:
# PORT=3001
# DATA_DIR=.
# LOG_LEVEL=info
# DEV_MODE=true

# Security: Set to true if using HTTPS (required for internet-exposed deployments)
# When true, session cookies will only be sent over HTTPS connections
# REQUIRE_TLS=false
