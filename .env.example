# TapeDeck Configuration
# Note: Plex servers, Home Assistant, and Apple TVs are now configured
# via the web-based setup wizard (creates config.yml).
# The setup wizard will guide you through connecting to your servers.

PORT=3001
DATABASE_PATH=./data/tapedeck.db
LOG_LEVEL=debug
SESSION_SECRET=generate_random_secret_minimum_32_characters

# Legacy Plex Configuration (backward compatibility - will be deprecated)
# PLEX_URL=http://192.168.1.100:32400
