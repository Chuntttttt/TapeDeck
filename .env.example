# Plex Configuration
PLEX_URL=http://192.168.1.100:32400
PLEX_SERVER_ID=your_plex_server_id_here

# Home Assistant Configuration
HA_URL=http://192.168.1.101:8123
HA_TOKEN=your_long_lived_access_token_here

# Apple TV Configuration
APPLE_TV_ENTITY=media_player.apple_tv

# TapeDeck Configuration
PORT=3001
DATABASE_PATH=./data/tapedeck.db
LOG_LEVEL=info
SESSION_SECRET=generate_random_secret_minimum_32_characters
